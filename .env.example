# B2 GEO/SEO Analyzer — Variáveis de Ambiente

# ──── Database ────
DATABASE_URL=postgresql://b2_geo:b2_geo_local@localhost:5432/b2_geo_seo

# ──── Redis ────
REDIS_URL=redis://localhost:6379

# ──── Object Storage (MinIO local) ────
OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_BUCKET=b2-geo-artifacts
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# ──── API ────
PORT=3001
PUBLIC_API_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ──── Authentication (OIDC/OAuth 2.0) ────
AUTH_ISSUER=https://auth.example.com
AUTH_AUDIENCE=b2-geo-api

# ──── Encryption ────
ENCRYPTION_MASTER_KEY=change-me-in-production-use-32-bytes

# ──── AI Providers (REQUIRED for GEO Semantic Analysis) ────
# OpenAI API compatible. Suporta OpenAI, Azure OpenAI, proxies compatíveis.
# Sem esta chave, o GEO Score usará avaliação neutra (score fixo 50).
OPENAI_API_KEY=sk-sua-chave-aqui
# Endpoint customizado (Azure, DeepSeek, proxies). Deixe vazio para usar api.openai.com
# Para Azure: https://SEU-RECURSO.openai.azure.com/openai/deployments/SEU-DEPLOYMENT
OPENAI_BASE_URL=https://api.openai.com/v1
# Modelo a ser utilizado (padrão: gpt-4o-mini para custo/benefício)
OPENAI_MODEL=gpt-4o-mini
# ──── Optional: Other AI Providers ────
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ──── Optional: Google Search Console ────
# GSC_CLIENT_ID=...
# GSC_CLIENT_SECRET=...

# ──── Observability ────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info